# Model routing
LOCAL_MODEL_ENABLED=true
LOCAL_MODEL_ENDPOINT=http://host.docker.internal:11434
LOCAL_MODEL_MODEL=qwen2.5-coder:7b
LOCAL_MODEL_FAST_MODEL=qwen2.5-coder:1.5b-base
LOCAL_MODEL_FAST_TASK_TYPES=format,docs,tiny-refactor,rename,simple-test
CLAUDE_MODEL=claude-sonnet-4-6
FORCE_CLAUDE=false
FORCE_LOCAL=false
MODEL_ROUTE_LOG=.ai/route-log.jsonl

# Delegation lifecycle (scripts/delegate-local.sh + scripts/local-health.sh)
LOCAL_MODEL_TIMEOUT=120        # hard cap (s) per local generation before escalating
LOCAL_MODEL_MAX_OUTPUT=2048    # num_predict cap per local generation
LOCAL_MODEL_MIN_TPS=5          # tokens/sec floor; slower marks the model degraded
LOCAL_HEALTH_CACHE=.ai/local-health.json
LOCAL_HEALTH_TTL=300           # seconds a health probe stays valid
LOCAL_MODEL_PROBE_TIMEOUT=45   # max seconds for the health speed probe

# Optional feature toggles
CAVEMAN_ENABLED=1
CAVEMAN_INSTALL_SHA256=8ddef49c15f089c26affed3c31d97142c683e1d37a1499ae557281ca09c2712c
CAVEMAN_MODE=lite
BMAD_ENABLED=1

# ── GitHub auth ───────────────────────────────────────────────────────────────
# Do NOT put a GitHub token here (or in any env var / repo file). Authenticate
# in the container terminal with browser OAuth instead:
#   gh auth login --hostname github.com --git-protocol https --web
# The token lands in gh's config (a named volume outside the workspace), git
# uses it via gh's credential helper, and nothing is readable from the repo.
