# Env and secrets
.env
.env.*
!.env.example
secrets.*
*.pem
*.key
*.p12
*.pfx

# Agent and local tool state
# Ignore Claude runtime state and machine-local settings, but NOT template
# assets (.claude/commands/, .claude/settings.json, .claude/settings.json.example).
.claude/mcp.json
.claude/settings.local.json
.claude/todos/
.claude/cache/
.claude/history/
.claude/statsig/
.ai/

# BMAD generated output (installed at container start by scripts/install-bmad.sh;
# regenerated per-machine — never commit)
_bmad/
_bmad-output/
.claude/skills/bmad-*

# Python
__pycache__/
.pytest_cache/
.venv/
venv/

# Node
node_modules/
npm-debug.log*

# OS/editor
.DS_Store
.vscode/settings.json

# Devcontainer / tooling runtime artifacts (created in-container, not template assets)
.gitconfig
.cache/

# Build artifacts
dist/
build/
coverage/

# CI scan outputs (generated by semgrep.yml / container-scan.yml)
*.sarif
